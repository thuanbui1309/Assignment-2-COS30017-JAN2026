<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?android:colorBackground">

    <!-- Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            android:background="@color/primary"
            app:titleTextColor="@color/white"
            app:title="@string/car_details"
            app:navigationIcon="@drawable/ic_arrow_back" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- Car Image Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/car_card_bg">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/car_image_height_large">

                    <ImageView
                        android:id="@+id/iv_car"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitCenter"
                        android:padding="@dimen/spacing_sm"
                        android:contentDescription="@string/cd_car_image" />

                    <!-- Favourite Heart Overlay -->
                    <ImageButton
                        android:id="@+id/btn_favourite"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="@dimen/spacing_md"
                        android:src="@drawable/ic_favorite_border"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/cd_toggle_favourite"
                        android:scaleType="centerInside" />

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Car Name + Rating Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/spacing_lg">

                <TextView
                    android:id="@+id/tv_car_name"
                    style="@style/CarTitleStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <RatingBar
                    android:id="@+id/rb_rating"
                    style="?android:attr/ratingBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:stepSize="1"
                    android:isIndicator="true"
                    android:progressTint="@color/rating_star"
                    android:layout_marginStart="@dimen/spacing_sm" />

                <!-- Model • Year moved here next to rating -->
                <TextView
                    android:id="@+id/tv_model_year"
                    style="@style/SecondaryInfoStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="@dimen/spacing_lg"
                android:layout_marginBottom="@dimen/spacing_lg" />

            <!-- Specs Chips Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- Mileage Chip -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="@dimen/spec_chip_height"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_spec_chip"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:padding="@dimen/spacing_sm">

                    <TextView
                        android:id="@+id/tv_spec_km_value"
                        style="@style/SpecChipValueStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        style="@style/SpecChipLabelStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/spec_km" />

                </LinearLayout>

                <!-- Daily Cost Chip -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="@dimen/spec_chip_height"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_spec_chip"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:padding="@dimen/spacing_sm">

                    <TextView
                        android:id="@+id/tv_spec_cost_value"
                        style="@style/SpecChipValueStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        style="@style/SpecChipLabelStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/spec_cost" />

                </LinearLayout>

                <!-- Year Chip -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="@dimen/spec_chip_height"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_spec_chip"
                    android:padding="@dimen/spacing_sm">

                    <TextView
                        android:id="@+id/tv_spec_year_value"
                        style="@style/SpecChipValueStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        style="@style/SpecChipLabelStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/spec_year" />

                </LinearLayout>

            </LinearLayout>

            <!-- Credit Balance (shown for available cars) -->
            <LinearLayout
                android:id="@+id/layout_balance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/spacing_md">

                <TextView
                    style="@style/SectionTitleStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/your_balance"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tv_balance"
                    style="@style/CreditTextStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Booking Info (shown for rented cars) -->
            <LinearLayout
                android:id="@+id/layout_booking_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:layout_marginTop="@dimen/spacing_md">

                <TextView
                    style="@style/SectionTitleStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/booking_info"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tv_booking_details"
                    style="@style/CreditTextStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Rent Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_rent"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/rent_this_car"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:backgroundTint="@color/accent"
                android:layout_marginTop="@dimen/spacing_md"
                app:cornerRadius="@dimen/card_corner_radius" />
                
            <!-- Cancel Booking Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel_booking"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/cancel_booking"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/error"
                android:textColor="@color/error"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:layout_marginTop="@dimen/spacing_md"
                android:visibility="gone"
                app:cornerRadius="@dimen/card_corner_radius" />

        </LinearLayout>

    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
